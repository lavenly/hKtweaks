<resources>

    <style name="AppTheme" parent="Theme.Material3Expressive.Light.NoActionBar">
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.hKtweaks.Material3</item>
        <item name="banner_frame_drawable">@drawable/drawable_frame_light</item>
        <item name="appSurfaceColor">?attr/colorSurface</item>
        <item name="android:colorBackground">?attr/colorSurface</item>
        <item name="android:windowBackground">?attr/colorSurface</item>
        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="android:textColorSecondary">?attr/colorOnSurfaceVariant</item>
        <item name="android:textColorPrimaryInverse">?attr/colorOnSurfaceInverse</item>
        <item name="android:textAlignment">gravity</item>
        <item name="android:textDirection">locale</item>
        <item name="android:textViewStyle">@style/Widget.hKtweaks.Material3Expressive.TextView</item>
        <item name="colorAccent">?attr/colorPrimary</item>
        <item name="dynamicColorThemeOverlay">@null</item>
        <item name="dim_dialog_background">@color/dim_foreground_disabled_material_dark</item>
    </style>

    <style name="AppThemeDark" parent="Theme.Material3Expressive.Dark.NoActionBar">
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.hKtweaks.Material3</item>
        <item name="banner_frame_drawable">@drawable/drawable_frame_dark</item>
        <item name="appSurfaceColor">?attr/colorSurface</item>
        <item name="android:colorBackground">?attr/colorSurface</item>
        <item name="android:windowBackground">?attr/colorSurface</item>
        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="android:textColorSecondary">?attr/colorOnSurfaceVariant</item>
        <item name="android:textColorPrimaryInverse">?attr/colorOnSurfaceInverse</item>
        <item name="android:textAlignment">gravity</item>
        <item name="android:textDirection">locale</item>
        <item name="android:textViewStyle">@style/Widget.hKtweaks.Material3Expressive.TextView</item>
        <item name="colorAccent">?attr/colorPrimary</item>
        <item name="dynamicColorThemeOverlay">@null</item>
        <item name="dim_dialog_background">@color/dim_foreground_disabled_material_light</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>
    </style>

    <style name="AppThemeParent" parent="AppTheme" />

    <style name="AppThemeParentDark" parent="AppThemeDark" />

    <style name="Motion.hKtweaks.Material3Expressive.Default.Spatial" parent="">
        <item name="stiffness">380</item>
        <item name="damping">0.8</item>
    </style>

    <style name="Motion.hKtweaks.Material3Expressive.Fast.Spatial" parent="">
        <item name="stiffness">800</item>
        <item name="damping">0.6</item>
    </style>

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.Material3Expressive.Light" />

    <style name="Widget.hKtweaks.Material3Expressive.Toolbar"
        parent="Widget.Material3Expressive.Toolbar.OnSurface">
        <item name="actionMenuTextColor">?attr/colorOnSurface</item>
        <item name="colorControlNormal">?attr/colorOnSurface</item>
        <item name="navigationIconTint">?attr/colorOnSurface</item>
        <item name="subtitleTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="titleTextColor">?attr/colorOnSurface</item>
    </style>

    <style name="Widget.hKtweaks.Material3Expressive.TextView"
        parent="Widget.MaterialComponents.TextView">
        <item name="android:textAppearance">@style/TextAppearance.hKtweaks.Body</item>
    </style>

    <style name="Widget.hKtweaks.Material3Expressive.IconButton.Standard"
        parent="Widget.Material3Expressive.Button.IconButton.Standard">
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="iconPadding">0dp</item>
        <item name="iconSize">24dp</item>
        <item name="materialSizeOverlay">@style/SizeOverlay.Material3Expressive.Button.IconButton.Small</item>
    </style>

    <style name="Widget.hKtweaks.Material3Expressive.IconButton.Tonal"
        parent="Widget.Material3Expressive.Button.IconButton.Tonal">
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="iconPadding">0dp</item>
        <item name="iconSize">24dp</item>
        <item name="materialSizeOverlay">@style/SizeOverlay.Material3Expressive.Button.IconButton.Small</item>
    </style>

    <style name="Widget.hKtweaks.Material3Expressive.IconButton.Filled"
        parent="Widget.Material3Expressive.Button.IconButton.Filled">
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="iconPadding">0dp</item>
        <item name="iconSize">24dp</item>
        <item name="materialSizeOverlay">@style/SizeOverlay.Material3Expressive.Button.IconButton.Small</item>
    </style>

    <style name="Widget.hKtweaks.Material3Expressive.IconButton.Outlined"
        parent="Widget.Material3Expressive.Button.IconButton.Outlined">
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="iconPadding">0dp</item>
        <item name="iconSize">24dp</item>
        <item name="materialSizeOverlay">@style/SizeOverlay.Material3Expressive.Button.IconButton.Small</item>
    </style>

    <style name="Widget.hKtweaks.Material3Expressive.FloatingActionButton"
        parent="Widget.Material3Expressive.FloatingActionButton">
        <item name="backgroundTint">?attr/colorSecondaryContainer</item>
        <item name="tint">?attr/colorOnSecondaryContainer</item>
    </style>

    <style name="Widget.hKtweaks.Material3Expressive.Banner"
        parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerHigh</item>
        <item name="cardElevation">0dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.ExtraLarge</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.hKtweaks.Material3Expressive.MaterialSwitch"
        parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="materialThemeOverlay">@style/ThemeOverlay.Material3Expressive</item>
    </style>

    <style name="Widget.hKtweaks.Material3Expressive.LoadingIndicator"
        parent="Widget.Material3.LoadingIndicator" />

    <style name="Widget.hKtweaks.Material3Expressive.LoadingIndicator.Contained"
        parent="Widget.Material3.LoadingIndicator.Contained" />

    <style name="Widget.hKtweaks.Material3Expressive.LoadingIndicator.Small"
        parent="Widget.Material3.LoadingIndicator">
        <item name="containerWidth">32dp</item>
        <item name="containerHeight">32dp</item>
        <item name="indicatorSize">24dp</item>
    </style>

    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">?android:attr/textColorSecondary</item>
    </style>

    <style name="ThemeOverlay.hKtweaks.RecoveryCheckBox" parent="">
        <item name="colorControlNormal">?attr/colorOnSurfaceVariant</item>
        <item name="colorControlActivated">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textAppearance">@style/TextAppearance.hKtweaks.Body</item>
    </style>

    <style name="PreferenceThemeOverlay.hKtweaks.Material3" parent="PreferenceThemeOverlay">
        <item name="preferenceStyle">@style/Preference.hKtweaks.Material3</item>
        <item name="preferenceCategoryStyle">@style/Preference.Category.hKtweaks.Material3</item>
        <item name="preferenceCategoryTitleTextAppearance">@style/TextAppearance.hKtweaks.ItemTitleSmall</item>
    </style>

    <style name="Preference.hKtweaks.Material3" parent="Preference.Material">
        <item name="android:layout">@layout/preference_material3</item>
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="Preference.Category.hKtweaks.Material3" parent="Preference.Category.Material">
        <item name="android:layout">@layout/preference_category_material3</item>
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="ShapeAppearanceOverlay.hKtweaks.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="TextAppearance.hKtweaks.ScreenTitle"
        parent="TextAppearance.Material3.TitleLarge.Emphasized" />

    <style name="TextAppearance.hKtweaks.SectionTitle"
        parent="TextAppearance.Material3.TitleMedium.Emphasized" />

    <style name="TextAppearance.hKtweaks.ItemTitle"
        parent="TextAppearance.Material3.TitleMedium" />

    <style name="TextAppearance.hKtweaks.ItemTitle.Emphasized"
        parent="TextAppearance.Material3.TitleMedium.Emphasized" />

    <style name="TextAppearance.hKtweaks.ItemTitleSmall"
        parent="TextAppearance.Material3.TitleSmall" />

    <style name="TextAppearance.hKtweaks.Body"
        parent="TextAppearance.Material3.BodyMedium" />

    <style name="TextAppearance.hKtweaks.BodyLarge"
        parent="TextAppearance.Material3.BodyLarge" />

    <style name="TextAppearance.hKtweaks.Body.Emphasized"
        parent="TextAppearance.Material3.BodyMedium.Emphasized" />

    <style name="TextAppearance.hKtweaks.Supporting"
        parent="TextAppearance.Material3.BodySmall" />

    <style name="TextAppearance.hKtweaks.Supporting.Emphasized"
        parent="TextAppearance.Material3.BodySmall.Emphasized" />

    <style name="TextAppearance.hKtweaks.Label"
        parent="TextAppearance.Material3.LabelMedium" />

    <style name="TextAppearance.hKtweaks.Label.Emphasized"
        parent="TextAppearance.Material3.LabelMedium.Emphasized" />

    <style name="TextAppearance.hKtweaks.LabelSmall"
        parent="TextAppearance.Material3.LabelSmall" />

    <style name="TextAppearance.hKtweaks.Code"
        parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="TextAppearance.hKtweaks.NavigationItem"
        parent="TextAppearance.Material3.LabelLarge" />

</resources>
