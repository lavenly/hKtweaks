<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="MergeRootFrame">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/theme_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="32dp">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/theme_color"
                android:textAppearance="@style/TextAppearance.hKtweaks.SectionTitle"
                android:textColor="?attr/colorOnSurface" />

            <HorizontalScrollView
                android:id="@+id/theme_palette_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/theme_palette"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="@string/theme_mode_section"
                android:textAppearance="@style/TextAppearance.hKtweaks.SectionTitle"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Filled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:cardElevation="0dp"
                app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.ExtraLarge">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/theme_mode_system"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@null"
                            app:srcCompat="@drawable/ic_theme_system"
                            app:tint="?attr/colorOnSurfaceVariant" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/theme_mode_system"
                                android:textAppearance="@style/TextAppearance.hKtweaks.ItemTitle"
                                android:textColor="?attr/colorOnSurface" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/theme_mode_system_summary"
                                android:textAppearance="@style/TextAppearance.hKtweaks.Supporting"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/theme_mode_system_radio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="?attr/colorOutlineVariant" />

                    <LinearLayout
                        android:id="@+id/theme_mode_light"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@null"
                            app:srcCompat="@drawable/ic_theme_light"
                            app:tint="?attr/colorOnSurfaceVariant" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/theme_mode_light"
                                android:textAppearance="@style/TextAppearance.hKtweaks.ItemTitle"
                                android:textColor="?attr/colorOnSurface" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/theme_mode_light_summary"
                                android:textAppearance="@style/TextAppearance.hKtweaks.Supporting"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/theme_mode_light_radio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="?attr/colorOutlineVariant" />

                    <LinearLayout
                        android:id="@+id/theme_mode_dark"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@null"
                            app:srcCompat="@drawable/ic_theme_dark"
                            app:tint="?attr/colorOnSurfaceVariant" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/theme_mode_dark"
                                android:textAppearance="@style/TextAppearance.hKtweaks.ItemTitle"
                                android:textColor="?attr/colorOnSurface" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/theme_mode_dark_summary"
                                android:textAppearance="@style/TextAppearance.hKtweaks.Supporting"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/theme_mode_dark_radio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="?attr/colorOutlineVariant" />

                    <LinearLayout
                        android:id="@+id/theme_mode_amoled"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@null"
                            app:srcCompat="@drawable/ic_theme_amoled"
                            app:tint="?attr/colorOnSurfaceVariant" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/theme_mode_amoled"
                                android:textAppearance="@style/TextAppearance.hKtweaks.ItemTitle"
                                android:textColor="?attr/colorOnSurface" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/theme_mode_amoled_summary"
                                android:textAppearance="@style/TextAppearance.hKtweaks.Supporting"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/theme_mode_amoled_radio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="@string/theme_preview"
                android:textAppearance="@style/TextAppearance.hKtweaks.SectionTitle"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Outlined"
                android:layout_width="240dp"
                android:layout_height="360dp"
                android:layout_gravity="center_horizontal"
                android:contentDescription="@string/theme_preview"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardElevation="0dp"
                app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.ExtraLarge"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="@string/app_name"
                        android:textAppearance="@style/TextAppearance.hKtweaks.ItemTitle.Emphasized"
                        android:textColor="?attr/colorOnSurface" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:contentDescription="@null"
                                app:srcCompat="@drawable/ic_chart"
                                app:tint="?attr/colorOnSurfaceVariant" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/overall"
                                android:textAppearance="@style/TextAppearance.hKtweaks.LabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:contentDescription="@null"
                                app:srcCompat="@drawable/ic_device"
                                app:tint="?attr/colorOnSurfaceVariant" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/device"
                                android:textAppearance="@style/TextAppearance.hKtweaks.LabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:gravity="center"
                                android:orientation="horizontal">

                                <com.google.android.material.imageview.ShapeableImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:contentDescription="@null"
                                    app:srcCompat="@drawable/ic_cpu"
                                    app:tint="?attr/colorPrimary" />

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    android:text="@string/cpu"
                                    android:textAppearance="@style/TextAppearance.hKtweaks.LabelSmall"
                                    android:textColor="?attr/colorPrimary" />
                            </LinearLayout>

                            <View
                                android:layout_width="40dp"
                                android:layout_height="4dp"
                                android:background="?attr/colorPrimary" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="8dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="8dp">

                        <com.google.android.material.card.MaterialCardView
                            style="@style/Widget.Material3.CardView.Filled"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                            app:cardElevation="0dp"
                            app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Full">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="14dp"
                                android:paddingEnd="8dp">

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/apply_on_boot"
                                    android:textAppearance="@style/TextAppearance.hKtweaks.Body.Emphasized"
                                    android:textColor="?attr/colorOnSurface" />

                                <com.google.android.material.materialswitch.MaterialSwitch
                                    style="@style/Widget.hKtweaks.Material3Expressive.MaterialSwitch"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:checked="true"
                                    android:clickable="false"
                                    android:focusable="false"
                                    android:importantForAccessibility="no"
                                    android:scaleX="0.75"
                                    android:scaleY="0.75" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            style="@style/Widget.Material3.CardView.Filled"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:layout_marginTop="8dp"
                            app:cardBackgroundColor="?attr/colorPrimaryContainer"
                            app:cardElevation="0dp"
                            app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Large">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/theme_preview_cpu_title"
                                    android:textAppearance="@style/TextAppearance.hKtweaks.ItemTitle.Emphasized"
                                    android:textColor="?attr/colorOnPrimaryContainer" />

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/theme_preview_cpu_summary"
                                    android:textAppearance="@style/TextAppearance.hKtweaks.Supporting"
                                    android:textColor="?attr/colorOnPrimaryContainer" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            style="@style/Widget.Material3.CardView.Filled"
                            android:layout_width="match_parent"
                            android:layout_height="112dp"
                            android:layout_marginTop="8dp"
                            app:cardBackgroundColor="?attr/colorSurfaceContainer"
                            app:cardElevation="0dp"
                            app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Large">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="55dp"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp">

                                    <com.google.android.material.textview.MaterialTextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="@string/cpu_max_freq"
                                        android:textAppearance="@style/TextAppearance.hKtweaks.Supporting.Emphasized"
                                        android:textColor="?attr/colorOnSurface" />

                                    <com.google.android.material.textview.MaterialTextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/theme_preview_frequency"
                                        android:textAppearance="@style/TextAppearance.hKtweaks.Label.Emphasized"
                                        android:textColor="?attr/colorPrimary" />
                                </LinearLayout>

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="1dp"
                                    android:layout_marginStart="12dp"
                                    android:layout_marginEnd="12dp"
                                    android:background="?attr/colorOutlineVariant" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="55dp"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp">

                                    <com.google.android.material.textview.MaterialTextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="@string/cpu_governor"
                                        android:textAppearance="@style/TextAppearance.hKtweaks.Supporting.Emphasized"
                                        android:textColor="?attr/colorOnSurface" />

                                    <com.google.android.material.textview.MaterialTextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/theme_preview_governor"
                                        android:textAppearance="@style/TextAppearance.hKtweaks.Label.Emphasized"
                                        android:textColor="?attr/colorPrimary" />
                                </LinearLayout>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/app_bar_main" />
</FrameLayout>
